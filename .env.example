# Optional remote backend URL. Leave empty to use the built-in local demo/fallback mode.
VITE_API_URL=

# Local HTTPS dev certificates created with mkcert.
VITE_TLS_CERT_FILE=.certs/localhost+127.0.0.1.pem
VITE_TLS_KEY_FILE=.certs/localhost+127.0.0.1-key.pem
VITE_TLS_CA_FILE=

# Local Redis
REDIS_URL=redis://localhost:6379

# Local coordination API used by the Redis/agent dashboard.
COORDINATION_API_HOST=127.0.0.1
COORDINATION_API_PORT=8765
VITE_COORDINATION_API_URL=http://127.0.0.1:8765
